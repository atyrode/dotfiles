#!@shell@
# shellcheck shell=bash disable=SC1008,SC2239
set -euo pipefail

readonly managed_agents='@agents@'
readonly managed_config='@config@'
readonly codex_command='@codex@'
readonly profile_name='atyrode'
readonly EX_USAGE=64 EX_DATAERR=65 EX_CANTCREAT=73 EX_TEMPFAIL=75

profile_root="${CODEX_PROFILE_ROOT:-$HOME/.codex-profiles}"
active_path="${CODEX_HOME:-$HOME/.codex}"
state_file="$profile_root/.active-profile"
lock_dir="$profile_root/.codex-use.lock"
journal="$profile_root/.codex-use.transaction"

die() { local code="$1"; shift; printf 'codex-use: %s\n' "$*" >&2; exit "$code"; }
valid_profile() { [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] || die "$EX_USAGE" "invalid profile: $1"; }
canonical_profile() { [[ "$1" != main ]] || { printf 'default\n'; return; }; printf '%s\n' "$1"; }
atomic_write() { local path="$1" value="$2" temp; temp="$(mktemp "${path}.XXXXXX")"; printf '%s\n' "$value" >"$temp"; chmod 600 "$temp"; mv -f "$temp" "$path"; }

release_lock() { [[ ! -d "$lock_dir" ]] || { rm -f "$lock_dir/pid"; rmdir "$lock_dir" 2>/dev/null || true; }; }
acquire_lock() {
  mkdir -p "$profile_root"
  if ! mkdir "$lock_dir" 2>/dev/null; then
    local owner=''; [[ ! -r "$lock_dir/pid" ]] || read -r owner <"$lock_dir/pid"
    if [[ "$owner" =~ ^[0-9]+$ ]] && kill -0 "$owner" 2>/dev/null; then die "$EX_TEMPFAIL" "another invocation holds the profile lock (pid $owner)"; fi
    rm -f "$lock_dir/pid"; rmdir "$lock_dir" 2>/dev/null || die "$EX_TEMPFAIL" "profile lock requires recovery: $lock_dir"
    mkdir "$lock_dir" || die "$EX_TEMPFAIL" "could not acquire profile lock"
  fi
  printf '%s\n' "$$" >"$lock_dir/pid"
  trap release_lock EXIT INT TERM
  [[ -z "${CODEX_USE_TEST_HOLD_SECONDS:-}" ]] || sleep "$CODEX_USE_TEST_HOLD_SECONDS"
}

current_profile() {
  local value=default
  if [[ -r "$state_file" ]]; then read -r value <"$state_file"; fi
  value="$(canonical_profile "$value")"; valid_profile "$value"; printf '%s\n' "$value"
}

backup_managed_collision() {
  local path="$1" source="$2" target backup
  if [[ -L "$path" ]]; then
    target="$(readlink "$path")"; [[ "$target" != "$source" ]] || return 1
  elif [[ ! -e "$path" ]]; then return 1; fi
  backup="$path.pre-managed.$(date +%Y%m%d%H%M%S).$$"
  mv "$path" "$backup"
  printf 'Preserved existing managed-path content at %s\n' "$backup" >&2
}

install_link() {
  local directory="$1" name="$2" source="$3" temp
  local path="$directory/$name"
  mkdir -p "$directory"; chmod 700 "$directory"
  backup_managed_collision "$path" "$source" || true
  [[ ! -L "$path" || "$(readlink "$path")" != "$source" ]] || return 0
  temp="$path.next.$$"; rm -f "$temp"; ln -s "$source" "$temp"; mv -f "$temp" "$path"
}

# Codex persists trust decisions and settings edits into config.toml and
# follows symlinks to the write target, so a live config linked into the
# read-only Nix store fails every such write. Repair that state into the
# mutable real file the layout promises, seeded from the link target.
ensure_mutable_config() {
  local path="$1/config.toml" target temp
  [[ -L "$path" ]] || return 0
  target="$(readlink -f "$path" || true)"
  [[ "$target" == /nix/store/* ]] || return 0
  temp="$path.next.$$"; rm -f "$temp"
  if [[ -r "$target" ]]; then cp "$target" "$temp"; else : >"$temp"; fi
  chmod 600 "$temp"; mv -f "$temp" "$path"
  printf 'Replaced store-symlinked %s with a mutable copy\n' "$path" >&2
}

install_managed_files() {
  install_link "$1" AGENTS.md "$managed_agents"
  install_link "$1" "$profile_name.config.toml" "$managed_config"
  ensure_mutable_config "$1"
}

clear_journal() { [[ ! -d "$journal" ]] || { rm -f "$journal"/*; rmdir "$journal"; }; }
journal_value() { local value; read -r value <"$journal/$1"; printf '%s\n' "$value"; }
recover() {
  [[ -d "$journal" ]] || return 0
  local phase from to staged from_path to_path
  phase="$(journal_value phase)"; from="$(journal_value from)"; to="$(journal_value to)"; staged="$(journal_value staged)"
  from_path="$profile_root/$from"; to_path="$profile_root/$to"
  case "$phase" in
    prepared) clear_journal ;;
    active-staged)
      [[ -e "$active_path" || ! -d "$staged" ]] || mv "$staged" "$active_path"
      clear_journal
      ;;
    target-active)
      [[ ! -e "$to_path" && -d "$active_path" ]] && mv "$active_path" "$to_path"
      [[ -e "$active_path" || ! -d "$staged" ]] || mv "$staged" "$active_path"
      clear_journal
      ;;
    layout-complete)
      atomic_write "$state_file" "$to"
      clear_journal
      ;;
    legacy-link-staged)
      [[ -e "$active_path" || ! -L "$staged" ]] || mv "$staged" "$active_path"
      clear_journal
      ;;
    legacy-layout-complete)
      atomic_write "$state_file" "$to"
      rm -f "$staged"
      clear_journal
      ;;
    *) die "$EX_DATAERR" "unknown recovery phase in $journal" ;;
  esac
  printf 'Recovered interrupted profile transaction (%s -> %s).\n' "$from" "$to" >&2
}

migrate_active_symlink() {
  [[ -L "$active_path" ]] || return 0
  local target selected staged
  target="$(readlink -f "$active_path")"
  case "$target" in
    "$profile_root"/*) ;;
    *) die "$EX_DATAERR" "$active_path points outside $profile_root: $target" ;;
  esac
  [[ -d "$target" ]] || die "$EX_DATAERR" "active legacy profile target is missing: $target"
  selected="${target##*/}"; valid_profile "$selected"; staged="$profile_root/.legacy-active-link.$$"
  mkdir "$journal" || die "$EX_TEMPFAIL" "transaction journal already exists"
  printf 'legacy\n' >"$journal/from"; printf '%s\n' "$selected" >"$journal/to"; printf '%s\n' "$staged" >"$journal/staged"; printf 'prepared\n' >"$journal/phase"
  mv "$active_path" "$staged"; printf 'legacy-link-staged\n' >"$journal/phase"
  [[ "${CODEX_USE_FAILPOINT:-}" != legacy-link-staged ]] || exit 99
  mv "$target" "$active_path"; printf 'legacy-layout-complete\n' >"$journal/phase"
  atomic_write "$state_file" "$selected"; rm -f "$staged"; clear_journal
}

ensure_layout() {
  mkdir -p "$profile_root"
  [[ ! -L "$active_path" ]] || die "$EX_DATAERR" "$active_path is a legacy symlink; run codex-use migrate"
  mkdir -p "$active_path"; chmod 700 "$active_path" "$profile_root"
}

converge_all() {
  ensure_layout; install_managed_files "$active_path"
  local directory
  for directory in "$profile_root"/*; do [[ ! -d "$directory" || "$directory" == "$lock_dir" || "$directory" == "$journal" ]] || install_managed_files "$directory"; done
}

codex_processes() { pgrep -u "$(id -u)" -af '(^|[ /])(\.codex-wrapped|codex)([[:space:]]|$)' || true; }
ensure_no_processes() { local processes; processes="$(codex_processes)"; [[ -z "$processes" ]] || die "$EX_TEMPFAIL" "Codex processes are running; close them before switching profiles"; }

switch_profile() {
  local to from from_path to_path staged phase
  to="$(canonical_profile "$1")"; valid_profile "$to"; from="$(current_profile)"
  ensure_layout
  [[ "$to" != "$from" ]] || { printf 'active Codex profile: %s\n' "$from"; return; }
  ensure_no_processes
  from_path="$profile_root/$from"; to_path="$profile_root/$to"; staged="$profile_root/.switch-current.$$"
  [[ ! -e "$from_path" ]] || die "$EX_CANTCREAT" "inactive destination collision for current profile: $from_path"
  install_managed_files "$active_path"
  mkdir -p "$to_path"; install_managed_files "$to_path"
  mkdir "$journal" || die "$EX_TEMPFAIL" "transaction journal already exists"
  printf '%s\n' "$from" >"$journal/from"; printf '%s\n' "$to" >"$journal/to"; printf '%s\n' "$staged" >"$journal/staged"; printf 'prepared\n' >"$journal/phase"
  mv "$active_path" "$staged"; printf 'active-staged\n' >"$journal/phase"
  [[ "${CODEX_USE_FAILPOINT:-}" != active-staged ]] || exit 99
  mv "$to_path" "$active_path"; printf 'target-active\n' >"$journal/phase"
  [[ "${CODEX_USE_FAILPOINT:-}" != target-active ]] || exit 99
  mv "$staged" "$from_path"; printf 'layout-complete\n' >"$journal/phase"
  atomic_write "$state_file" "$to"; clear_journal
  printf 'active Codex profile: %s\n' "$to"
}

migrate() {
  migrate_active_symlink
  ensure_layout
  local legacy name destination
  for legacy in "$HOME"/.codex-*; do
    [[ -d "$legacy" && ! -L "$legacy" ]] || continue
    [[ "$legacy" != "$profile_root" ]] || continue
    name="${legacy##*/.codex-}"; valid_profile "$name"; destination="$profile_root/$(canonical_profile "$name")"
    [[ ! -e "$destination" ]] || die "$EX_CANTCREAT" "legacy profile collision: $destination"
    mv "$legacy" "$destination"
  done
  converge_all; atomic_write "$state_file" "$(current_profile)"
}

status() {
  local json=0 current; [[ "${1:-}" != --json ]] || json=1; current="$(current_profile)"
  if [[ "$json" == 1 ]]; then
    printf '{"activeProfile":"%s","activePath":"%s","managed":{"AGENTS.md":"portable","atyrode.config.toml":"portable"},"mutable":["config.toml","auth.json","history.jsonl","sessions","plugins","cache"],"secrets":["auth.json"],"recoveryPending":%s}\n' "$current" "$active_path" "$([[ -d "$journal" ]] && echo true || echo false)"
  else printf 'active Codex profile: %s\nCODEX_HOME=%s\nmanaged: AGENTS.md, %s.config.toml\nmutable: config.toml, auth, history, sessions, plugins, caches\n' "$current" "$active_path" "$profile_name"; fi
}

usage() { printf '%s\n' 'Usage: codex-use [status [--json]|converge|migrate|list|path [PROFILE]|ps|stop [--force]|login PROFILE [ARGS...]|PROFILE]'; }
main() {
  local command="${1:-status}"; shift || true
  acquire_lock; recover
  case "$command" in
    status) status "$@" ;;
    converge) converge_all ;;
    migrate) migrate ;;
    list) printf '%s\n' "$(current_profile)"; find "$profile_root" -mindepth 1 -maxdepth 1 -type d ! -name '.*' -printf '%f\n' 2>/dev/null | sort -u ;;
    path) local selected="${1:-$(current_profile)}"; selected="$(canonical_profile "$selected")"; [[ "$selected" == "$(current_profile)" ]] && printf '%s\n' "$active_path" || printf '%s/%s\n' "$profile_root" "$selected" ;;
    ps) codex_processes ;;
    stop) local signal=TERM; [[ "${1:-}" != --force ]] || signal=KILL; codex_processes | while read -r pid _; do kill "-$signal" "$pid" 2>/dev/null || true; done ;;
    login) [[ $# -ge 1 ]] || die "$EX_USAGE" "login requires a profile"; local selected="$1"; shift; switch_profile "$selected"; release_lock; trap - EXIT INT TERM; exec "$codex_command" login --device-auth "$@" ;;
    help|-h|--help) usage ;;
    *) [[ $# -eq 0 ]] || die "$EX_USAGE" "unexpected arguments"; switch_profile "$command" ;;
  esac
}
main "$@"
